<!DOCTYPE html>
<html>
<head>
  <title>AuraHairCollections</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: #fff5f9;
      color: #444;
      text-align: center;
    }

    header {
      background: #f8c8dc;
      padding: 40px 20px;
      color: #5a3d4d;
    }

    h1 { margin: 0; font-size: 34px; letter-spacing: 1px; }

    .section { padding: 40px 20px; }

    .price-box {
      background: white;
      margin: 15px auto;
      padding: 25px;
      width: 90%;
      max-width: 420px;
      border-radius: 20px;
      box-shadow: 0 8px 20px rgba(248, 200, 220, 0.3);
    }

    .price-box h3 { margin: 10px 0; color: #d88ca5; }

    .booking-form {
      background: white;
      padding: 25px;
      border-radius: 20px;
      max-width: 420px;
      margin: auto;
      box-shadow: 0 8px 20px rgba(248, 200, 220, 0.3);
    }

    input, select, textarea {
      width: 100%;
      padding: 12px;
      margin: 10px 0;
      border-radius: 10px;
      border: 1px solid #f2d6e2;
      font-size: 14px;
    }

    button {
      background: #f4a7c2;
      color: white;
      border: none;
      padding: 14px;
      width: 100%;
      border-radius: 30px;
      font-weight: bold;
      cursor: pointer;
      font-size: 15px;
    }

    button:hover { background: #e892b2; }

    .payment-buttons {
      margin-top: 20px;
    }

    .payment-buttons a, .payment-buttons form {
      display: block;
      margin: 10px auto;
      width: 90%;
      max-width: 300px;
    }

    footer {
      margin-top: 50px;
      padding: 20px;
      background: #f8c8dc;
      color: #5a3d4d;
    }

    .deposit { font-size: 13px; margin-top: 15px; color: #777; }
  </style>
</head>

<body>

<header>
  <h1>AuraHairCollections</h1>
  <p>Soft Luxury Hair Experience 💗</p>
</header>

<div class="section">
  <h2>Services & Prices</h2>

  <div class="price-box">
    <h3>Knotless Braids</h3>
    <p>Starting at $120</p>
  </div>

  <div class="price-box">
    <h3>Silk Press</h3>
    <p>$80</p>
  </div>

  <div class="price-box">
    <h3>Quick Weave</h3>
    <p>$95</p>
  </div>

  <div class="price-box">
    <h3>Wig Install</h3>
    <p>$110</p>
  </div>

  <div class="price-box">
    <h3>Hair Coloring</h3>
    <p>$70+</p>
  </div>

  <h2>Bundles 💝</h2>

  <div class="price-box">
    <h3>Bundle 1: Braids + Silk Press</h3>
    <p>$180</p>
  </div>

  <div class="price-box">
    <h3>Bundle 2: Quick Weave + Wig Install</h3>
    <p>$190</p>
  </div>

  <div class="price-box">
    <h3>Full Hair Package</h3>
    <p>All Services Included $350</p>
  </div>
</div>

<div class="section">
  <h2>Book Appointment 💌</h2>

  <div class="booking-form">
    <form action="https://formsubmit.co/YOUR-EMAIL@gmail.com" method="POST">
      <input type="text" name="Name" placeholder="Full Name" required>
      <input type="email" name="Email" placeholder="Email Address" required>
      <input type="tel" name="Phone" placeholder="Phone Number" required>

      <select name="Service" required>
        <option value="">Select Service / Bundle</option>
        <option>Knotless Braids</option>
        <option>Silk Press</option>
        <option>Quick Weave</option>
        <option>Wig Install</option>
        <option>Hair Coloring</option>
        <option>Bundle 1: Braids + Silk Press</option>
        <option>Bundle 2: Quick Weave + Wig Install</option>
        <option>Full Hair Package</option>
      </select>

      <input type="date" name="Preferred Date" required>
      <textarea name="Message" placeholder="Extra details (length, color, etc.)"></textarea>

      <button type="submit">Submit Booking 💗</button>
      <p class="deposit">$20 Deposit Required To Secure Appointment (Non-Refundable)</p>
    </form>

    <div class="payment-buttons">
      <!-- Apple Pay Button (via Stripe link) -->
      <form action="https://buy.stripe.com/YOUR-APPLE-PAY-LINK" method="POST">
        <button type="submit">Pay with Apple Pay 💳</button>
      </form>

      <!-- CashApp Button -->
      <a href="https://cash.app/$YOURCASHAPPUSERNAME" target="_blank">
        <button type="button">Pay with CashApp 💸</button>
      </a>
    </div>
  </div>
</div>

<footer>
  <p>Follow us on IG: @AuraHairCollections</p>
</footer>

</body>
</html>
